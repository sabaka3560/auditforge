# Copy this file to .env and fill in real values before starting the server.
# Never commit .env to version control.

# PostgreSQL — use asyncpg driver for FastAPI, psycopg2 for RQ workers (auto-swapped)
DATABASE_URL=postgresql+asyncpg://auditforge:changeme@localhost:5432/auditforge

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Redis — used by RQ job queue
REDIS_URL=redis://localhost:6379/0

# Storage root — uploaded files and generated reports land here
STORAGE_PATH=storage

# Bundled ideal files directory (fallback when no DB record exists for a tenant)
IDEALS_DIR=ideals

# Default fuzzy match threshold (0–100)
FUZZY_THRESHOLD_DEFAULT=80
