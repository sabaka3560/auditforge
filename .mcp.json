{
  "mcpServers": {
    "mcpdoc": {
      "command": "uvx",
      "args": [
        "mcpdoc"
      ],
      "env": {
        "DOCS_URLS": "https://pandas.pydata.org/docs/;https://openpyxl.readthedocs.io/en/stable/;https://fastapi.tiangolo.com/"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "env": {}
    }
  }
}